# Copy thành .env.local và điền giá trị thật
# ❌ KHÔNG commit file .env.local lên Git

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=true

# App
APP_NAME=AI Agent
APP_VERSION=1.0.0

# LLM
LLM_PROVIDER=gemini
GEMINI_API_KEY=
# GOOGLE_API_KEY= also works if you already use that name
LLM_MODEL=gemini-3.1-flash-lite
LLM_TIMEOUT_SECONDS=20

# Security — BẮT BUỘC thay trong production
AGENT_API_KEY=dev-key-change-me-in-production
JWT_SECRET=dev-jwt-secret-change-in-production

# Rate & Budget
RATE_LIMIT_PER_MINUTE=10
DAILY_BUDGET_USD=5.0
MONTHLY_BUDGET_USD=10.0

# Storage
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=3600

# CORS
ALLOWED_ORIGINS=http://localhost:3000
